<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Persistent app bar; no in-content duplicate screen title. -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/app_bar_height"
            app:title="@string/app_bar_title"
            app:logo="@drawable/ic_shield_check"
            app:logoDescription="@string/cd_app_logo" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable content. Centered and width-capped on wide windows. -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/content_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <com.pcontrol.app.ui.MaxWidthLinearLayout
            android:id="@+id/content_column"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="@dimen/content_padding_h"
            android:paddingEnd="@dimen/content_padding_h"
            android:paddingTop="@dimen/content_padding_v"
            android:paddingBottom="@dimen/spacing_xxl"
            app:maxContentWidth="@dimen/content_max_width">

            <!-- Status hero: filled in by CapabilityRenderer. -->
            <TextView
                android:id="@+id/status_hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Pcontrol.HeroTitle"
                android:importantForAccessibility="yes"
                android:accessibilityHeading="true"
                android:accessibilityLiveRegion="polite" />

            <!-- ─── Required setup ────────────────────────────────────── -->
            <TextView
                android:id="@+id/section_required"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/section_required"
                android:accessibilityHeading="true"
                android:textAppearance="@style/TextAppearance.Pcontrol.SectionHeading" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Pcontrol.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_usage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Pcontrol.CapabilityTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/cap_usage_rationale"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_usage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/cap_usage_action" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Pcontrol.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_accessibility"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Pcontrol.CapabilityTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/cap_accessibility_rationale"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_accessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/cap_accessibility_action" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Pcontrol.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Pcontrol.CapabilityTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/cap_notifications_rationale"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_notifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/cap_notifications_action" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Pcontrol.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_battery"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Pcontrol.CapabilityTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/cap_battery_rationale"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_battery"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/cap_battery_action" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Server connection ───────────────────────────────── -->
            <TextView
                android:id="@+id/section_server"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/section_server"
                android:accessibilityHeading="true"
                android:textAppearance="@style/TextAppearance.Pcontrol.SectionHeading" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Pcontrol.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_server"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Pcontrol.CapabilityTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/server_rationale"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_server"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/server_action_edit" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── Updates (optional) ───────────────────────────────── -->
            <TextView
                android:id="@+id/section_updates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/section_updates"
                android:accessibilityHeading="true"
                android:textAppearance="@style/TextAppearance.Pcontrol.SectionHeading" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.Pcontrol.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/status_updater"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/TextAppearance.Pcontrol.CapabilityTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/updater_rationale"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_updater"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/updater_action" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_auto_update"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/updates_auto_update" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/updates_auto_update_subtext"
                        android:textAppearance="?attr/textAppearanceBodySmall" />

                    <Button
                        android:id="@+id/btn_check_update"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/touch_target_min"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/updates_check_action" />

                    <!-- Stage 5: durable inline update status. -->
                    <ProgressBar
                        android:id="@+id/update_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:indeterminate="true"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/update_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:accessibilityLiveRegion="polite"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </com.pcontrol.app.ui.MaxWidthLinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Persistent bottom CTA. -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurfaceContainer"
        android:elevation="0dp">

        <Button
            android:id="@+id/btn_start"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/touch_target_min"
            android:layout_margin="@dimen/content_padding_h"
            android:text="@string/start_monitoring"
            android:enabled="false" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>