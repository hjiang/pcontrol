<?xml version="1.0" encoding="utf-8"?>
<!--
Unraid Docker template for pcontrol-server.

Install: copy this file to /boot/config/plugins/dockerMan/templates-user/
on the Unraid server, then go to Docker → Add Container and select "pcontrol".

See deploy/unraid/README.md for full setup instructions.
-->
<Container version="2">
  <Name>pcontrol</Name>
  <Repository>ghcr.io/hjiang/pcontrol-server:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <Privileged>false</Privileged>
  <Support>https://github.com/hjiang/pcontrol</Support>
  <Project>https://github.com/hjiang/pcontrol</Project>
  <Overview>Parental control server for Android devices. Tracks app/website usage and enforces daily time limits. Web dashboard at port 7285.</Overview>
  <Category>Productivity:</Category>
  <WebUI>http://[IP]:[PORT:7285]</WebUI>
  <ExtraParams>--user 99:100</ExtraParams>
  <Requires></Requires>

  <Config Name="Web port" Target="7285" Default="7285" Mode="tcp"
          Description="Web dashboard and API port (container &amp; host)"
          Type="Port" Display="always" Required="true" Mask="false">7285</Config>

  <Config Name="Appdata path" Target="/data" Default="/mnt/user/appdata/pcontrol/"
          Mode="rw"
          Description="Persistent storage for the SQLite database"
          Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pcontrol/</Config>

  <Config Name="Admin password hash" Target="PCONTROL_ADMIN_HASH" Default=""
          Mode=""
          Description="bcrypt hash of the admin password. Generate with: docker run --rm -i ghcr.io/hjiang/pcontrol-server hash-password"
          Type="Variable" Display="always" Required="true" Mask="true"></Config>
</Container>
