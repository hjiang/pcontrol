<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>pcontrol</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, -apple-system, sans-serif; line-height: 1.5; color: #222; background: #f8f9fa; }
  nav { background: #333; color: #fff; padding: 0.5rem 1rem; display: flex; gap: 1rem; align-items: center; }
  nav a { color: #fff; text-decoration: none; }
  nav a:hover { text-decoration: underline; }
  nav form { margin-left: auto; }
  main { max-width: 800px; margin: 1rem auto; padding: 0 1rem; }
  h1 { margin: 0.5rem 0; }
  h2 { margin-top: 1.5rem; }
  table { border-collapse: collapse; width: 100%; }
  th, td { padding: 0.4rem 0.6rem; text-align: left; }
  .card { border: 1px solid #ccc; border-radius: 6px; padding: 1rem; margin: 0.75rem 0; background: #fff; }
  .bar-bg { background: #eee; height: 16px; border-radius: 4px; overflow: hidden; margin-top: 4px; }
  .bar-fill { height: 16px; border-radius: 4px; transition: width 0.3s; }
  .badge { font-weight: bold; }
  .badge-ok { color: #2a2; }
  .badge-warn { color: #e80; }
  .badge-blocked { color: #d22; }
  .muted { color: #666; font-size: 0.9em; }
  .badge-online { color: #090; }
  .badge-offline { color: #999; }
  .battery { margin-left: 0.5em; font-size: 0.9em; }
  .battery-low { color: #c00; font-weight: bold; }
  .top-apps { margin-top: 6px; font-size: 0.9em; color: #555; }
  button, .btn { cursor: pointer; }
  .btn-link { background: none; border: none; color: #06c; text-decoration: underline; font: inherit; cursor: pointer; padding: 0; }
  hr { margin: 1rem 0; border: none; border-top: 1px solid #ddd; }
</style>
<script src="/static/htmx.min.js"></script>
</head>
<body>
<nav>
  <a href="/"><strong>pcontrol</strong></a>
  <a href="/devices/new">Register device</a>
  <form action="/logout" method="post" style="display:inline"><button style="background:none;border:none;color:#fff;font:inherit;cursor:pointer">Logout</button></form>
</nav>
<main>
{{.ContentHTML}}
</main>
</body>
</html>
